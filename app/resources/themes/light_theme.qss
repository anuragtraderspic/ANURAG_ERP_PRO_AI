QWidget{

background:#F4F7FC;

color:#1E293B;

font-size:11pt;

font-family:"Segoe UI";

}


QPushButton{

background:#2563EB;

color:white;

border:none;

border-radius:8px;

padding:8px;

}


QPushButton:hover{

background:#1D4ED8;

}


QLineEdit{

background:white;

border:1px solid #DDE3EA;

border-radius:8px;

padding:6px;

}


QComboBox{

background:white;

border:1px solid #DDE3EA;

border-radius:8px;

padding:6px;

}